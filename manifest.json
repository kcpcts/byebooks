{
  "manifest_version": 3,
  "name": "ByeBooks",
  "description": "Automate ZyBooks participation activities — animations, multiple choice, short answer, drag-and-drop matching, and block ordering.",
  "version": "3.0",
  "permissions": ["scripting"],
  "host_permissions": ["https://learn.zybooks.com/*"],
  "content_scripts": [
    {
      "matches": [
        "https://learn.zybooks.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  }
}